# =============================================================================
# Sollos 3 environment variables
# Copy this file to .env.local and fill in real values.
# Never commit .env.local — only this example file is tracked.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase
# Get these from https://supabase.com/dashboard → your project → Settings → API
# -----------------------------------------------------------------------------

# Public Supabase URL — exposed to the browser, safe to commit on Vercel as a public env var.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Public anon key — exposed to the browser, RLS-protected, safe to commit on Vercel as a public env var.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — SERVER ONLY. NEVER expose to the browser. Bypasses RLS.
# Used only by /src/lib/supabase/admin.ts in server actions and route handlers.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------

# The canonical URL the app is deployed at. Used for redirects and email links.
# In dev: http://localhost:3000
# In prod: set to your Vercel URL (e.g. https://cleanops.vercel.app)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Sentry (Phase 10 — error tracking)
# Sign up at https://sentry.io, create a Next.js project, then run
#   pnpm add @sentry/nextjs
#   npx @sentry/wizard -i nextjs
# The wizard will populate the DSN. Until then leave blank.
# -----------------------------------------------------------------------------

# Public Sentry DSN — safe to expose to the browser.
NEXT_PUBLIC_SENTRY_DSN=

# Sentry org / project slugs used by the build-time source-map upload.
SENTRY_ORG=
SENTRY_PROJECT=

# Auth token for source-map upload. SERVER ONLY. Treat like a secret.
SENTRY_AUTH_TOKEN=

# -----------------------------------------------------------------------------
# Resend (Phase 10 — transactional email)
# Sign up at https://resend.com and create an API key.
# When the key is missing the email helpers no-op (logged to console).
# -----------------------------------------------------------------------------

RESEND_API_KEY=
EMAIL_FROM="Sollos 3 <noreply@sollos.app>"

# -----------------------------------------------------------------------------
# Stripe (Phase 10 — billing, scaffolded but disabled)
# The webhook route at /api/stripe/webhook returns 503 unless STRIPE_ENABLED=true.
# When you're ready to charge:
#   1. pnpm add stripe
#   2. Wire src/lib/stripe.ts to call stripe.webhooks.constructEvent
#   3. Set STRIPE_ENABLED=true and fill in the keys below
# -----------------------------------------------------------------------------

STRIPE_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# -----------------------------------------------------------------------------
# Twilio (Phase 11 — freelancer bench SMS dispatch)
# Outbound-only SMS to freelancers when admin broadcasts a shift offer.
# When TWILIO_ENABLED !== "true" the sendSms() helper no-ops and dispatch rows
# are marked `skipped_disabled` so the claim flow can still be tested end to
# end by clicking the generated claim links on the offer detail page.
#
# To go live (after A2P 10DLC registration — ~$55 one-time + $11/mo):
#   1. Create a Twilio account at https://twilio.com, buy a local long code
#   2. Register an A2P 10DLC brand + campaign (required for US SMS to stick)
#   3. Fill in the values below and set TWILIO_ENABLED=true
#   4. Verify by sending yourself a test offer from /app/freelancers
# -----------------------------------------------------------------------------

TWILIO_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# -----------------------------------------------------------------------------
# Phase 12 — Invoicing integrations
#
# Sollos registers ONCE with each provider as an OAuth app (the cleaning
# company's owner clicks "Connect" in /app/settings/integrations and
# authorises our app against THEIR processor account). These vars are the
# platform-level credentials — same for every Sollos customer. The
# per-org access tokens live encrypted in `integration_connections`.
#
# Token encryption key
# --------------------
# All OAuth access + refresh tokens are encrypted at rest with AES-256-GCM
# before being written to the DB. Generate one with:
#
#   node -e "console.log('base64:' + require('crypto').randomBytes(32).toString('base64'))"
#
# This MUST be set in production. Rotate by dual-decrypting for a window.
# -----------------------------------------------------------------------------

INTEGRATION_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Stripe Connect (invoicing — separate from the billing scaffold above)
#
# Register at https://dashboard.stripe.com/settings/connect/onboarding-options
#   1. Enable "Standard" Connect accounts
#   2. Set the redirect URI to $NEXT_PUBLIC_SITE_URL/api/integrations/stripe/callback
#   3. Grab the Connect client id (starts with `ca_...`)
# Use LIVE keys in prod and TEST keys everywhere else.
# -----------------------------------------------------------------------------

STRIPE_CONNECT_CLIENT_ID=
STRIPE_CONNECT_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Square
#
# Register at https://developer.squareup.com/apps
#   1. Create an application
#   2. Set OAuth redirect URL to $NEXT_PUBLIC_SITE_URL/api/integrations/square/callback
#   3. Request these scopes: PAYMENTS_READ, ORDERS_READ, MERCHANT_PROFILE_READ
#   4. Toggle Sandbox vs Production per environment
# -----------------------------------------------------------------------------

SQUARE_ENVIRONMENT=sandbox
SQUARE_APPLICATION_ID=
SQUARE_APPLICATION_SECRET=
SQUARE_WEBHOOK_SIGNATURE_KEY=

# -----------------------------------------------------------------------------
# QuickBooks Online (Intuit)
#
# Register at https://developer.intuit.com/app/developer/dashboard
#   1. Create an app with "Accounting" scope
#   2. Add $NEXT_PUBLIC_SITE_URL/api/integrations/quickbooks/callback as a
#      redirect URI (you must add BOTH sandbox and prod URIs)
#   3. Intuit issues a client id + client secret per environment
# -----------------------------------------------------------------------------

QUICKBOOKS_ENVIRONMENT=sandbox
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_WEBHOOK_VERIFIER_TOKEN=

# -----------------------------------------------------------------------------
# Google Calendar
#
# Register at https://console.cloud.google.com/apis/credentials
#   1. Create a project (or reuse your existing one)
#   2. Enable the Google Calendar API
#   3. Create an OAuth 2.0 Client ID (Web application type)
#   4. Add $NEXT_PUBLIC_SITE_URL/api/integrations/google-calendar/callback
#      as an authorized redirect URI
#   5. Copy the client ID and client secret below
# Scopes requested: calendar.events, userinfo.email
# -----------------------------------------------------------------------------

GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Sage Business Cloud Accounting
#
# Register at https://developerselfservice.sageone.com/
#   1. Create an application
#   2. Set callback URL to $NEXT_PUBLIC_SITE_URL/api/integrations/sage/callback
#   3. Request scope: full_access
#   4. Copy the client ID and client secret below
# Note: Sage refresh tokens rotate on every use (31-day expiry).
# -----------------------------------------------------------------------------

SAGE_CLIENT_ID=
SAGE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Web Push Notifications (VAPID)
#
# Generate a VAPID key pair with:
#   npx web-push generate-vapid-keys
#
# The public key is exposed to browsers. The private key is SERVER ONLY.
# When both are set, push notifications are enabled automatically.
# Without them, the push prompt won't appear and sends silently no-op.
# -----------------------------------------------------------------------------

NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
